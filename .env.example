# ─── PT SONTOLOYO Monitor — Environment Template ─────
# Developed by PAKDE XRESX DIGITAL STORE
# Copy to `.env` and fill in real values. NEVER commit .env to git.

# ─── Database ─────────────────────────────────────────
# SQLite (default — perfect for low-spec VPS):
DATABASE_URL="file:./prod.db"
# PostgreSQL (only if you outgrow SQLite):
# DATABASE_URL="postgresql://user:password@localhost:5432/ptsontoloyo?schema=public"

# ─── NextAuth ─────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-please-generate-a-strong-secret"
NEXTAUTH_URL="http://localhost:3000"

# ─── Default Admin (used by `npm run db:seed`) ────────
ADMIN_EMAIL="admin@ptsontoloyo.local"
ADMIN_PASSWORD="change-me-strong-password"
ADMIN_NAME="Super Admin"

# ─── Monitor Sync ─────────────────────────────────────
# Token used by an external cron to trigger /api/monitor/sync
# Generate with: openssl rand -hex 32
MONITOR_SYNC_TOKEN="change-me-monitor-sync-token"
# Default refresh interval (ms) the dashboard polls /api/servers/public
NEXT_PUBLIC_REFRESH_MS=10000

# ─── VPS Agent fetch defaults (used by lib/monitor) ───
VPS_FETCH_TIMEOUT_MS=4000
VPS_FETCH_RETRIES=2
