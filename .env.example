# =================================================================
#  PT Sontoloyo Monitor — environment template
#  Author / Developer: Pakde Xresx Digital Store
# =================================================================

# ─── Database ─────────────────────────────────────────
# SQLite (default — quick start, file-based, zero setup):
DATABASE_URL="file:./dev.db"
# PostgreSQL (recommended for production):
# DATABASE_URL="postgresql://user:password@localhost:5432/sontoloyo?schema=public"

# ─── NextAuth (admin login only) ──────────────────────
# Generate strong secret:  openssl rand -base64 32
NEXTAUTH_SECRET="change-me-please-generate-a-strong-secret"
NEXTAUTH_URL="http://localhost:3000"

# ─── Default Admin (used by `npm run db:seed`) ────────
ADMIN_EMAIL="admin@sontoloyo.local"
ADMIN_PASSWORD="admin123"
ADMIN_NAME="Super Admin"

# ─── Monitor Sync ─────────────────────────────────────
# Token used by an external cron to trigger /api/monitor/sync
MONITOR_SYNC_TOKEN="change-me-monitor-sync-token"
# How often the dashboard polls /api/servers/public (milliseconds)
NEXT_PUBLIC_REFRESH_MS=10000

# ─── VPS Agent fetch defaults (server-side) ───────────
VPS_FETCH_TIMEOUT_MS=4000
VPS_FETCH_RETRIES=2

# ─── Branding (visible to client — change to taste) ───
NEXT_PUBLIC_BRAND_NAME="PT Sontoloyo"
NEXT_PUBLIC_BRAND_SUFFIX="Monitor"
NEXT_PUBLIC_AUTHOR="Pakde Xresx Digital Store"

# ─── Contact (WhatsApp button on public homepage) ─────
# International format, no plus sign, e.g. 6281234567890
NEXT_PUBLIC_WHATSAPP_NUMBER=""
NEXT_PUBLIC_WHATSAPP_TEXT="Halo Admin, saya ingin info layanan VPN/Xray."
