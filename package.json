{
  "name": "sontoloyo-monitor",
  "version": "1.0.0",
  "private": true,
  "description": "PT Sontoloyo Monitor — premium realtime VPN/Xray server monitoring panel.",
  "author": "Pakde Xresx Digital Store",
  "license": "MIT",
  "scripts": {
    "predev": "node scripts/check-env.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/check-env.mjs",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "setup": "node scripts/check-env.mjs && prisma generate && prisma db push && tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "predb:seed": "node scripts/check-env.mjs && prisma db push --skip-generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts",
    "monitor:sync": "tsx scripts/sync-once.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.460.0",
    "next": "14.2.35",
    "next-auth": "^4.24.10",
    "nodemailer": "^7.0.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.4",
    "tar": "^7.5.15",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.6",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
