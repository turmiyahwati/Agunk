// Prisma schema for PT Sontoloyo Monitor — VPN/Xray monitoring panel.
// Default: SQLite for fast local dev. Switch provider to "postgresql"
// for production (no other code change needed).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NOTE: SQLite does not support native enums, so we store enum-like
// fields as String. The application validates them via TypeScript types
// (see `src/lib/enums.ts`) and Zod schemas in API routes.
//
//   status: "ONLINE" | "OFFLINE" | "FULL" | "WARNING" | "UNKNOWN"
//
// The User model only stores ADMIN accounts. Public visitors do not
// require a session — monitoring is open. Login is admin-only.

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Server {
  id          String   @id @default(cuid())
  name        String
  domain      String
  country     String   @default("ID")
  countryName String   @default("Indonesia")
  flag        String?
  provider    String   @default("Unknown")
  apiUrl      String?
  apiKey      String?
  enabled     Boolean  @default(true)
  refreshMs   Int      @default(10000)
  maxSlot     Int      @default(100)

  status       String   @default("UNKNOWN")
  activeUsers  Int      @default(0)
  pingMs       Int      @default(0)
  speedMbps    Int      @default(0)
  rxBytes      BigInt   @default(0)
  txBytes      BigInt   @default(0)
  uptimeSec    Int      @default(0)
  cpuPercent   Float    @default(0)
  ramPercent   Float    @default(0)

  sshActive    Boolean  @default(false)
  xrayActive   Boolean  @default(false)
  nginxActive  Boolean  @default(false)
  udpActive    Boolean  @default(false)

  totalSsh     Int      @default(0)
  totalXray    Int      @default(0)

  lastError    String?
  lastSyncAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  metrics     ServerMetric[]
}

model ServerMetric {
  id          String   @id @default(cuid())
  serverId    String
  server      Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  ts          DateTime @default(now())
  status      String
  activeUsers Int
  pingMs      Int
  speedMbps   Int
  rxBytes     BigInt
  txBytes     BigInt
  cpuPercent  Float
  ramPercent  Float

  @@index([serverId, ts])
}

// Generic key-value store for runtime-editable settings (e.g. logoUrl).
// Used by the admin → Branding page; no PII or secrets stored here.
model Setting {
  key       String   @id
  value     String?
  updatedAt DateTime @updatedAt
}

// Recent activity log surfaced on the public homepage.
// Stores ONLY non-sensitive metadata (protocol kind + server name +
// action + timestamp). Never store usernames, passwords, UUIDs, IPs,
// tokens, or any PII here.
model Activity {
  id         String   @id @default(cuid())
  protocol   String   // "SSH" | "VMESS" | "VLESS" | "TROJAN"
  serverName String
  action     String   @default("CREATE")
  createdAt  DateTime @default(now())

  @@index([createdAt])
}
