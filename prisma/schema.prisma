// Prisma schema for Agunk - VPN/Xray Monitor
// Default: SQLite for fast local dev. Switch provider to "postgresql" for production
// (no other code change needed; enums are stored as plain strings).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NOTE: SQLite does not support native enums, so we store the enum-like
// fields as String. The application validates them via TypeScript types
// (see `src/lib/enums.ts`) and Zod schemas in API routes.
//
//   role:   "ADMIN" | "MEMBER"
//   status: "ONLINE" | "OFFLINE" | "FULL" | "WARNING" | "UNKNOWN"

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("MEMBER")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Server {
  id          String   @id @default(cuid())
  name        String
  domain      String   // domain or IP
  country     String   @default("ID")
  countryName String   @default("Indonesia")
  flag        String?  // url to flag image (optional override)
  provider    String   @default("Unknown")
  apiUrl      String?  // base URL of the VPS agent, e.g. http://1.2.3.4:8787
  apiKey      String?  // API key for the VPS agent
  enabled     Boolean  @default(true)
  refreshMs   Int      @default(10000)
  maxSlot     Int      @default(100)

  // Last fetched / manually entered metrics (denormalized for quick read)
  status       String   @default("UNKNOWN")
  activeUsers  Int      @default(0)
  pingMs       Int      @default(0)
  speedMbps    Int      @default(0)
  rxBytes      BigInt   @default(0)
  txBytes      BigInt   @default(0)
  uptimeSec    Int      @default(0)
  cpuPercent   Float    @default(0)
  ramPercent   Float    @default(0)

  sshActive    Boolean  @default(false)
  xrayActive   Boolean  @default(false)
  nginxActive  Boolean  @default(false)
  udpActive    Boolean  @default(false)

  totalSsh     Int      @default(0)
  totalXray    Int      @default(0)

  lastError    String?
  lastSyncAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  metrics     ServerMetric[]
}

model ServerMetric {
  id          String   @id @default(cuid())
  serverId    String
  server      Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  ts          DateTime @default(now())
  status      String
  activeUsers Int
  pingMs      Int
  speedMbps   Int
  rxBytes     BigInt
  txBytes     BigInt
  cpuPercent  Float
  ramPercent  Float

  @@index([serverId, ts])
}
